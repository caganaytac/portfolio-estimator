PORT=3000
NODE_ENV=development

# Must match JWT_SECRET in users-service, portfolios-service, and evaluations-service.
JWT_SECRET=replace-with-a-long-shared-secret

USERS_SERVICE_URL=http://localhost:3001
PORTFOLIOS_SERVICE_URL=http://localhost:3002
EVALUATIONS_SERVICE_URL=http://localhost:3003

REQUEST_TIMEOUT_MS=5000
BODY_LIMIT=1mb
CORS_ORIGINS=http://localhost:5173
TRUST_PROXY=false

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200
